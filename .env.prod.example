# Copie para .env.prod e preencha com valores reais. NUNCA commitar o .env.prod (já está no
# .gitignore da pasta raiz — confirme antes de subir para o servidor).

# --- Banco / fila (uso interno do compose — não expostos ao host) ---
POSTGRES_USER=proptech
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=proptech

# --- Segredos da aplicação ---
# Gerar com: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=troque-por-um-valor-aleatorio-de-32-bytes-ou-mais
# Gerar com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=troque-por-uma-chave-fernet-valida

# --- Domínio (sem domínio ainda: deixe como está, acesso será só por IP:porta) ---
PLATFORM_DOMAIN=localhost

# --- Mercado Pago (opcional — deixe em branco se ainda não configurado) ---
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- Observabilidade (opcional) ---
SENTRY_DSN=

# --- Portas publicadas no host — AJUSTE se colidirem com outro serviço já rodando no servidor ---
# Antes de subir, confira com: ss -tlnp (ou netstat -tlnp) no servidor.
BACKEND_PORT=8001
FRONTEND_PORT=8090
